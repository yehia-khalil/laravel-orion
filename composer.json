{
    "name": "tailflow/laravel-orion",
    "description": "Orion for Laravel allows you to build a fully featured REST API based on your Eloquent models and relationships with the simplicity of Laravel as you love it.",
    "keywords": [
        "laravel",
        "api"
    ],
    "license": "MIT",
    "support": {
        "issues": "https://github.com/tailflow/laravel-orion/issues",
        "source": "https://github.com/tailflow/laravel-orion"
    },
    "authors": [
        {
            "name": "Aleksei Zarubin",
            "email": "alex@tailflow.org"
        }
    ],
    "require": {
        "php": ">=7.3",
        "ext-json": "*",
        "doctrine/dbal": "^2.9|^3.1|^4.0",
        "illuminate/bus": ">=8.0",
        "illuminate/contracts": ">=8.0",
        "illuminate/database": ">=8.0",
        "illuminate/http": ">=8.0",
        "illuminate/pagination": ">=8.0",
        "illuminate/support": ">=8.0",
        "symfony/yaml": "^5.3|^6.0|^7.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.0",
        "orchestra/testbench": "^6.0|^7.0|^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^6.0|^7.0|^8.0|^9.0|^10.0|^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Orion\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Orion\\Tests\\": "tests/",
            "Orion\\Tests\\Fixtures\\App\\": "tests/Fixtures/app/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev"
        },
        "laravel": {
            "providers": [
                "Orion\\OrionServiceProvider"
            ],
            "aliases": {
                "Orion": "Orion\\Facades\\Orion"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "kylekatarnls/update-helper": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
